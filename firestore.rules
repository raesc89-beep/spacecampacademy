rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Is the user authenticated and trying to modify their own document?
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /modules/{moduleId} {
      allow read: if true; // Any cadet can read module contents
      allow write: if isAdmin(); // Only admins can create/update modules
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // Parent portal mappings linking parent to child
    match /parent_mappings/{mappingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
